APP_NAME="WebBlocks CMS"
APP_SLOGAN="A modern block-based CMS"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_VERSION=0.1.2
APP_URL=http://localhost

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=sqlite
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=webblocks_cms
# DB_USERNAME=root
# DB_PASSWORD=

# Backup dump execution: auto, direct, ddev
# CMS_BACKUP_EXECUTION=auto

WEBBLOCKS_UPDATES_ENABLED=true
WEBBLOCKS_UPDATE_SERVER_ENABLED=true
WEBBLOCKS_UPDATE_SERVER_NAME="WebBlocks Update Server"
WEBBLOCKS_UPDATE_SERVER_BASE_URL=https://updates.webblocksui.com
WEBBLOCKS_UPDATE_SERVER_DEFAULT_CHANNEL=stable

WEBBLOCKS_UPDATE_CLIENT_ENABLED=true
# Update server base URL used by CMS clients
WEBBLOCKS_UPDATES_CLIENT_SERVER_URL=https://updates.webblocksui.com
WEBBLOCKS_UPDATE_CLIENT_CHANNEL=stable
WEBBLOCKS_UPDATE_CLIENT_PRODUCT=webblocks-cms
# WEBBLOCKS_UPDATE_CLIENT_CURRENT_VERSION=${APP_VERSION}
# WEBBLOCKS_UPDATE_CLIENT_SITE_URL=${APP_URL}
# WEBBLOCKS_UPDATE_CLIENT_INSTANCE_ID=
WEBBLOCKS_UPDATE_CLIENT_TIMEOUT_SECONDS=5
WEBBLOCKS_UPDATE_CLIENT_CONNECT_TIMEOUT_SECONDS=3
WEBBLOCKS_UPDATE_CLIENT_RETRY_TIMES=0
WEBBLOCKS_UPDATE_CLIENT_RETRY_SLEEP_MS=150

WEBBLOCKS_UPDATES_PUBLISH_ENABLED=true
WEBBLOCKS_UPDATES_PUBLISH_SERVER_URL=https://updates.webblocksui.com
# WEBBLOCKS_UPDATES_PUBLISH_TOKEN=
WEBBLOCKS_UPDATES_PUBLISH_PRODUCT=webblocks-cms
WEBBLOCKS_UPDATES_PUBLISH_CHANNEL=stable
WEBBLOCKS_UPDATES_PUBLISH_TIMEOUT=30

WEBBLOCKS_RELEASE_PRODUCT=webblocks-cms
WEBBLOCKS_RELEASE_PACKAGE_PREFIX=webblocks-cms
WEBBLOCKS_RELEASE_DEFAULT_CHANNEL=stable
WEBBLOCKS_RELEASE_DISK=local
WEBBLOCKS_RELEASE_OUTPUT_DIRECTORY=releases/builds
WEBBLOCKS_RELEASE_DOWNLOADS_DIRECTORY=app/public/releases
WEBBLOCKS_RELEASE_DOWNLOADS_URL_PREFIX=/storage/releases
WEBBLOCKS_RELEASE_EXCLUDE_VENDOR=true
WEBBLOCKS_RELEASE_EXCLUDE_GIT_METADATA=true
WEBBLOCKS_RELEASE_PUBLISH_ENABLED=true
WEBBLOCKS_RELEASE_PUBLISH_SERVER_URL=https://updates.webblocksui.com
# Release publish bearer token used by cms:release --publish and /api/updates/publish
# WEBBLOCKS_RELEASE_PUBLISH_TOKEN=
WEBBLOCKS_RELEASE_PUBLISH_TIMEOUT_SECONDS=30
WEBBLOCKS_RELEASE_PUBLISH_CONNECT_TIMEOUT_SECONDS=5

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false
