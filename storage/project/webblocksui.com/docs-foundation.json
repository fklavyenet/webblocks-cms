                    },
                    "translations": {
                      "en": {
                        "content": "<button data-wb-mode-set=\"dark\">Dark</button>\n<button data-wb-preset-set=\"minimal\">Minimal</button>\n<button data-wb-accent-set=\"forest\">Forest</button>\n<button data-wb-radius-set=\"soft\">Soft radius</button>\n<button data-wb-density-set=\"compact\">Compact</button>\n<button data-wb-shadow-set=\"soft\">Soft shadow</button>\n<button data-wb-font-set=\"editorial\">Editorial font</button>"
                      }
                    }
                  }
                ]
              }
            ]
