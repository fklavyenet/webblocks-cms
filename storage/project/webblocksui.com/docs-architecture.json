                    "variant": "h2",
                    "translations": {
                      "en": {
                        "title": "What this site is not doing"
                      }
                    }
                  },
                  {
                    "key": "no-custom-classes-heading",
                    "type": "header",
                    "variant": "h3",
                    "translations": {
                      "en": {
                        "title": "No custom classes"
                      }
                    }
                  },
                  {
                    "key": "no-custom-classes-copy",
                    "type": "rich-text",
                    "translations": {
                      "en": {
                        "content": "<p>Every class used in <code>docs/</code> comes from the shipped package CSS.</p>"
                      }
                    }
                  },
                  {
                    "key": "no-style-scripts-heading",
                    "type": "header",
                    "variant": "h3",
                    "translations": {
                      "en": {
                        "title": "No style scripts"
                      }
                    }
                  },
                  {
                    "key": "no-style-scripts-copy",
                    "type": "rich-text",
                    "translations": {
                      "en": {
                        "content": "<p>Layout, spacing, and presentation are left to CSS. No JavaScript is added to fake CSS concerns.</p>"
                      }
                    }
                  },
                  {
                    "key": "no-behavior-css-heading",
                    "type": "header",
                    "variant": "h3",
                    "translations": {
                      "en": {
                        "title": "No behavior CSS"
                      }
                    }
                  },
                  {
                    "key": "no-behavior-css-copy",
                    "type": "rich-text",
                    "translations": {
                      "en": {
                        "content": "<p>Overlays, tabs, drawers, dropdowns, and theme switching rely on shipped JavaScript hooks instead of CSS hacks.</p>"
                      }
                    }
                  }
                ]
              }
            ]
          },
