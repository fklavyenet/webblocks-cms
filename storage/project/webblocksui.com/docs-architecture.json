                  "layout_name": "Architecture intro container"
                },
                "children": [
                  {
                    "key": "content-header-block",
                    "type": "content_header",
                    "variant": "h1",
                    "translations": {
                      "en": {
                        "title": "Architecture",
                        "subtitle": "WebBlocks UI is intentionally layered so that tokens, structure, visible building blocks, and full-screen compositions do not blur together."
                      }
                    }
                  }
                ]
              }
            ]
          },
          {
            "key": "current-layer-model",
            "type": "section",
            "settings": {
              "layout_name": "The current layer model"
            },
            "children": [
              {
                "key": "current-layer-model-container",
                "type": "container",
                "settings": {
                  "width": "lg",
                  "layout_name": "The current layer model container"
                },
                "children": [
                  {
                    "key": "current-layer-model-heading",
                    "type": "header",
                    "variant": "h2",
                    "translations": {
                      "en": {
                        "title": "The current layer model"
                      }
                    }
                  },
                  {
                    "key": "current-layer-model-links",
                    "type": "link-list",
                    "children": [
                      {
                        "key": "layer-foundation",
                        "type": "link-list-item",
                        "url": "foundation.html",
                        "translations": {
                          "en": {
                            "title": "foundation",
                            "subtitle": "tokens and theme axes",
                            "content": "This layer defines tokens, dark mode, presets, accent sets, radius, density, shadow, font, border, reset, element-level rules, and the default styling for raw HTML such as headings and code."
                          }
                        }
                      },
                      {
                        "key": "layer-utilities",
                        "type": "link-list-item",
                        "url": "utilities.html",
                        "translations": {
                          "en": {
                            "title": "utilities",
                            "subtitle": "small helper classes",
                            "content": "Use utilities for small adjustments after the main pattern and primitive decisions are already correct. Spacing, text sizing, alignment, color, and visibility helpers live here."
                          }
                        }
                      },
                      {
                        "key": "layer-layout",
                        "type": "link-list-item",
                        "url": "layout.html",
                        "translations": {
                          "en": {
                            "title": "layout",
                            "subtitle": "containers and structural flow",
                            "content": "This layer contains container, stack, cluster, split, grid, row/column, navbar, sidebar, and shell structure. It solves frame and flow, not button-level UI."
                          }
                        }
                      },
                      {
                        "key": "layer-primitives-surfaces",
                        "type": "link-list-item",
                        "url": "primitives.html",
                        "translations": {
                          "en": {
                            "title": "primitives + surfaces",
                            "subtitle": "controls and framed content regions",
                            "content": "Buttons, forms, tables, dropdowns, drawers, modals, and tabs are primitives. Cards, stats, callouts, lists, toolbars, filter bars, and empty states are surfaces. Public classification follows UI role, not folder name."
                          }
                        }
                      },
                      {
                        "key": "layer-patterns",
                        "type": "link-list-item",
                        "url": "patterns.html",
                        "translations": {
                          "en": {
                            "title": "patterns",
                            "subtitle": "screen-level compositions",
                            "content": "Patterns define real page jobs such as dashboard shell, auth shell, settings shell, content shell, and marketing surfaces."
                          }
                        }
                      },
                      {
                        "key": "layer-icons",
                        "type": "link-list-item",
                        "url": "icons.html",
                        "translations": {
                          "en": {
                            "title": "icons",
                            "subtitle": "asset layer",
                            "content": "Icons are delivered as class-based assets and aliases in this guide. They support primitives and patterns rather than acting as a separate UI layer."
                          }
                        }
                      }
                    ]
                  }
                ]
              }
            ]
          },
          {
            "key": "build-order-matters",
            "type": "section",
            "settings": {
              "layout_name": "Build order matters"
            },
            "children": [
              {
                "key": "build-order-matters-container",
                "type": "container",
                "settings": {
                  "width": "lg",
                  "layout_name": "Build order matters container"
                },
                "children": [
                  {
                    "key": "build-order-matters-heading",
                    "type": "header",
                    "variant": "h2",
                    "translations": {
                      "en": {
                        "title": "Build order matters"
                      }
                    }
                  },
                  {
                    "key": "build-order-matters-copy",
                    "type": "rich-text",
                    "translations": {
                      "en": {
                        "content": "<p>The package build order is intentional. Later layers rely on earlier layers already being present.</p><ol><li>foundation</li><li>utilities</li><li>layout</li><li>primitives</li><li>patterns</li><li>icons</li></ol>"
                      }
                    }
                  },
                  {
                    "key": "build-order-warning",
                    "type": "alert",
                    "settings": {
                      "variant": "warning"
                    },
                    "translations": {
                      "en": {
                        "title": "Do not flatten the layer model",
                        "content": "If a class primarily defines page structure, keep it in layout or patterns. If it is an atomic control, keep it in primitives. If it is a framed content region, treat it as a surface. If it only nudges spacing or text alignment, keep it in utilities."
                      }
                    }
                  }
                ]
              }
            ]
          },
          {
            "key": "what-this-site-is-not-doing",
            "type": "section",
            "settings": {
              "layout_name": "What this site is not doing"
            },
            "children": [
              {
                "key": "what-this-site-is-not-doing-container",
                "type": "container",
                "settings": {
                  "width": "lg",
                  "layout_name": "What this site is not doing container"
                },
                "children": [
                  {
                    "key": "what-this-site-is-not-doing-heading",
